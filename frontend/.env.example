# Backend API URL
# Usar para desarrollo local con backend en localhost:3000
VITE_API_URL=http://localhost:3000

# Configuración HMR (Hot Module Replacement) para Vite
# Usado cuando accedes desde una dirección IP remota (ej: Raspberry Pi)
# Reemplaza 100.99.181.34 con tu IP o hostname
VITE_HMR_HOST=localhost
VITE_HMR_PORT=5174
VITE_HMR_PROTOCOL=ws

# Ejemplo de configuración remota:
# VITE_HMR_HOST=100.99.181.34
# VITE_API_URL=http://100.99.181.34:3000
