PORT=
NODE_ENV=
UPLOAD_DIR=
MAX_FILE_SIZE=
ALLOWED_MIME_TYPES=
CORS_ORIGIN=
JWT_SECRET=

# ============ APP IDENTIFIER ============
# Nombre único de la app (para multi-app en mismo Redis)
APP_NAME=reproductor-flac

# ============ REDIS CACHE (Preload) ============
# URL de conexión a Redis con número de BD (0-15)
# Formato: redis://[usuario[:contraseña]@]host[:puerto]/[base_de_datos]
# Ejemplos:
#   - Desarrollo local: redis://localhost:6379/0
#   - Docker Compose: redis://redis:6379/0
#   - Con autenticación: redis://:password@localhost:6379/0
# BD 0 = Reproductor FLAC, BD 1 = Otra app, etc
REDIS_URL=redis://localhost:6379/0

# Prefijo de claves Redis (junto con BD, previene colisiones)
# Ejemplo: REDIS_KEY_PREFIX=audio:
# Resultado: DB 0 > audio:preload:archivo.flac
#            DB 0 > audio:metadata:archivo.flac
REDIS_KEY_PREFIX=audio:

# TTL para caché de PRECARGA (segundos, default: 86400 = 24h)
# Archivos grandes que se mantienen en caché para reproducción
REDIS_PRELOAD_TTL=86400

# TTL para caché de METADATOS (segundos, default: 3600 = 1h)
# Título, artista, álbum, carátulas - se renuevan rápido
REDIS_METADATA_TTL=3600